{
  "name": "quality-gates",
  "version": "0.1.0",
  "description": "実装後レビュー・テスト分析・自動 lint の品質ゲート",
  "depends": ["core", "audit"],
  "hooks": {
    "PreToolUse": [
      {"file": "check-context-optimization.py", "matcher": "Read|Grep|Bash"}
    ],
    "PostToolUse": [
      {"file": "post-implementation-review.py", "matcher": "Edit|Write"},
      {"file": "post-test-analysis.py", "matcher": "Bash"},
      {"file": "lint-on-save.py", "matcher": "Edit|Write"},
      "test-tampering-detector.py",
      {"file": "test-gate-checker.py", "matcher": "Edit|Write"}
    ],
    "Stop": ["turn-end-summary.py"]
  },
  "files": [
    "hooks/check-context-optimization.py",
    "hooks/post-implementation-review.py",
    "hooks/post-test-analysis.py",
    "hooks/lint-on-save.py",
    "hooks/test-tampering-detector.py",
    "hooks/test-gate-checker.py",
    "hooks/turn-end-summary.py"
  ],
  "skills": ["review", "tdd", "design-tracker", "release-readiness"],
  "agents": [],
  "rules": ["skill-review-policy"],
  "scripts": [],
  "config": []
}
